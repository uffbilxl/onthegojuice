.next/
out/

# Dependencies
node_modules/

# Environment variables — NEVER commit secrets
.env.local
.env*.local

# public/ copies of static files — generated at build time (prebuild), not committed
# Run: npm run prebuild before `npm run dev` for local development
public/images/
public/css/
public/js/
public/*.html

# macOS
.DS_Store
Icon

# Python
__pycache__/
*.pyc
make_placeholders.py

# Misc
*.log
npm-debug.log*
